# Keep the image build context lean: only Go sources and module files are
# needed. Written as a blocklist because the scaffolded allowlist form
# (** + !**/*.go) is not honored by pattern matchers that refuse to
# re-include files under a **-excluded directory.
bin/
dist/
config/
hack/
test/
**/*_test.go
*.md
.golangci.yml
.dockerignore
Dockerfile
